GOOGLE_API_KEY=mock-key-for-ci
GITHUB_PAT=your_actual_or_mock_pat_here

# Neon Postgres (LangGraph checkpoint persistence)
# From Neon dashboard: Connection details → connection string (use pooled URL if available)
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Arize AX tracing (optional locally; required for observability in Arize)
ARIZE_SPACE_ID=your-space-id
ARIZE_API_KEY=your-api-key
ARIZE_PROJECT_NAME=github-intelligence-agent
